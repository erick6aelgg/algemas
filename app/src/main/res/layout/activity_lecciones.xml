<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA: Lista de Lecciones
    Patrones: Infinite List, List Inlay, Escape Hatch (toolbar)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ── Toolbar / Escape Hatch ────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AlgePlus.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── Encabezado con saludo ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/descripcion_lecciones"
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ── RecyclerView: Infinite List ──────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLecciones"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerBlock"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
