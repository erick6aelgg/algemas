<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA: Menú Principal
    Patrones: Clear Entry Points, Input Prompt
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ── Ola decorativa superior ─────────────────────────────────────── -->
    <View
        android:id="@+id/waveTop"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── INPUT PROMPT: Campo de nombre de usuario (Clear Entry Point 1) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilUsername"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/main_btn_margin_start"
        android:layout_marginEnd="@dimen/main_btn_margin_start"
        android:layout_marginTop="@dimen/main_btn_margin_top"
        android:hint="@string/hint_username"
        app:boxBackgroundColor="@color/colorWhiteTranslucent"
        app:boxStrokeColor="@color/colorBackground"
        app:hintTextColor="@color/colorBackground"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="@color/colorBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName|textCapWords"
            android:maxLines="1"
            android:textColor="@color/colorBackground"
            android:imeOptions="actionDone" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Logo de la aplicación ────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="@dimen/logo_size"
        android:layout_height="@dimen/logo_size"
        android:src="@drawable/movilin"
        android:contentDescription="@string/desc_logo"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/waveTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── Nombre de la app ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="@dimen/text_title"
        android:textColor="@color/colorPrimary"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── Tagline ───────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textSize="@dimen/text_caption"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── Divisor ───────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="@color/colorPrimaryLight"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── CLEAR ENTRY POINT 2: Botón Local ────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRepaso"
        style="@style/AlgePlus.Button.Primary"
        android:layout_width="@dimen/main_btn_width"
        android:layout_height="@dimen/main_btn_height"
        android:layout_marginStart="@dimen/main_btn_margin_start"
        android:layout_marginEnd="@dimen/main_btn_margin_end"
        android:layout_marginTop="@dimen/main_btn_margin_top"
        android:text="@string/btn_local"
        android:textSize="@dimen/text_body"
        app:icon="@null"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── CLEAR ENTRY POINT 3: Botón Conexion (deshabilitado) ───────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCompetencia"
        style="@style/AlgePlus.Button.Secondary"
        android:layout_width="@dimen/main_btn_width"
        android:layout_height="@dimen/main_btn_height"
        android:layout_marginStart="@dimen/main_btn_margin_start"
        android:layout_marginEnd="@dimen/main_btn_margin_end"
        android:layout_marginTop="@dimen/main_btn_margin_top"
        android:text="@string/btn_conexion"
        android:textSize="@dimen/text_caption"
        android:enabled="false"
        android:alpha="0.45"
        app:layout_constraintTop_toBottomOf="@id/btnRepaso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationY="@dimen/main_y_translation" />

    <!-- ── Versión ───────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_caption"
        android:textColor="@color/colorHint"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
