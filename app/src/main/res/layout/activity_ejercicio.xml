<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA: Muestra Ejercicio
    Patrones:
      – Escape Hatch: botón ← en barra superior
      – Sequence Map: barra de círculos de progreso
      – Prominent Done Button: "Verificar ✓"
      – Modal Panel: overlays de tip y felicitación (con dim)
      – Drag & Drop: tokenBoard de operadores
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  BARRA SUPERIOR: usuario + puntaje + escape hatch                  -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_top_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- ESCAPE HATCH -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="@string/desc_back"
            android:background="@android:color/transparent"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Chip de puntaje -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_score_chip">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_star"
                android:contentDescription="@string/desc_star" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 pts"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  ÁREA DE EJERCICIO (scrollable)                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollExercise"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/progressSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/exerciseContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

    </ScrollView>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  SECCIÓN INFERIOR FIJA                                            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/progressSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- SEQUENCE MAP: indicador de progreso con círculos -->
        <LinearLayout
            android:id="@+id/progressDots"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="12dp" />

        <!-- Botones Pista y Verificar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPista"
                style="@style/AlgePlus.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/btn_pista"
                android:textSize="15sp"
                android:layout_marginEnd="8dp" />

            <!-- PROMINENT DONE BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerificar"
                style="@style/AlgePlus.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:text="@string/btn_verificar"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- TOKEN BOARD: operadores arrastrables -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/colorPrimarySurface"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arrastra:"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginEnd="12dp" />

            <!-- Los tokens se agregan programáticamente en EjercicioActivity -->
            <LinearLayout
                android:id="@+id/tokenBoard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  OVERLAY OSCURO (MODAL PANEL – dim)                               -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/dimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorOverlay"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  MODAL PANEL: Pista                                               -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTip"
        style="@style/AlgePlus.Card.Modal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:visibility="gone"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_lightbulb"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_tip"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTipMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/colorOnBackground"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/aviso_pista"
                android:textSize="12sp"
                android:textColor="@color/colorSecondary"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarTip"
                style="@style/AlgePlus.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/btn_cerrar_tip" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  MODAL PANEL: Felicitación                                        -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFelicitacion"
        style="@style/AlgePlus.Card.Modal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Emoji de celebración grande -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="52sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFelicitacionMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorOnBackground"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <!-- Puntos ganados (gamificación) -->
            <TextView
                android:id="@+id/tvPuntosGanados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorGold"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAvanzar"
                style="@style/AlgePlus.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_avanzar"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
