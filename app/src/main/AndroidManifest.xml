<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".AlgePlusApp"
        android:allowBackup="true"
        android:icon="@drawable/movilin"
        android:roundIcon="@drawable/movilin"
        android:label="@string/app_name"
        android:theme="@style/Theme.AlgePlus"
        android:supportsRtl="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.LeccionesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.EjercicioActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.ResultadosActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>
